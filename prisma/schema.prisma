generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
  TESTER
  MODERATOR
  TEST_MANAGER
}

enum TesterKind {
  CROWD
  DEVELOPER
}

enum AccountStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

enum CampaignStage {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  TESTING
  BUG_REVIEW
  COMPLETED
}

enum SoftwareType {
  WEBSITE
  ANDROID_APP
  IOS_APP
  DESKTOP_SOFTWARE
}

enum AssignmentRole {
  CROWD_TESTER
  DEVELOPER_TESTER
  MODERATOR
  TEST_MANAGER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum BugSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum BugStatus {
  SUBMITTED
  APPROVED
  REJECTED
  DUPLICATE
  VALIDATED
}

enum AttachmentKind {
  SCREENSHOT
  VIDEO
  LOG
  ATTACHMENT
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model User {
  id                String               @id @default(cuid())
  name              String
  email             String               @unique
  passwordHash      String
  role              Role
  testerKind        TesterKind?
  accountStatus     AccountStatus        @default(PENDING_APPROVAL)
  isEmailVerified   Boolean              @default(false)
  country           String?
  language          String?
  testingExperience String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  devices           Device[]
  clientCampaigns   Campaign[]           @relation("ClientCampaigns")
  managerCampaigns  Campaign[]           @relation("ManagerCampaigns")
  assignments       CampaignAssignment[]
  invitations       CampaignInvitation[]
  bugReports        BugReport[]          @relation("ReporterBugs")
  moderatedReports  BugReport[]          @relation("ModeratorBugs")
  validatedReports  BugReport[]          @relation("ManagerBugs")
  auditLogs         AuditLog[]
  emailTokens       EmailToken[]
}

model Device {
  id               String   @id @default(cuid())
  userId           String
  deviceName       String
  osVersion        String
  browsers         String[]
  screenResolution String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Campaign {
  id                   String               @id @default(cuid())
  clientId             String
  testManagerId        String?
  projectName          String
  description          String
  softwareType         SoftwareType
  websiteUrl           String?
  downloadPath         String?
  testerCredentials    Json?
  stage                CampaignStage        @default(DRAFT)
  crowdTesterCount     Int                  @default(0)
  developerTesterCount Int                  @default(0)
  selectedCountries    String[]
  selectedPlatforms    String[]
  selectedBrowsers     String[]
  estimatedCost        Float                @default(0)
  moderatorSlots       Int                  @default(0)
  requirements         Json?
  analytics            Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  client               User                 @relation("ClientCampaigns", fields: [clientId], references: [id], onDelete: Cascade)
  testManager          User?                @relation("ManagerCampaigns", fields: [testManagerId], references: [id], onDelete: SetNull)
  assignments          CampaignAssignment[]
  invitations          CampaignInvitation[]
  tasks                TestingTask[]
  bugReports           BugReport[]
  auditLogs            AuditLog[]

  @@index([clientId, stage])
  @@index([testManagerId])
}

model CampaignAssignment {
  id             String         @id @default(cuid())
  campaignId     String
  userId         String
  assignmentRole AssignmentRole
  acceptedAt     DateTime?
  createdAt      DateTime       @default(now())
  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId, assignmentRole])
  @@index([userId, assignmentRole])
}

model CampaignInvitation {
  id         String           @id @default(cuid())
  campaignId String
  testerId   String
  status     InvitationStatus @default(PENDING)
  invitedAt  DateTime         @default(now())
  acceptedAt DateTime?
  expiresAt  DateTime?
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tester     User             @relation(fields: [testerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, testerId])
  @@index([testerId, status])
}

model TestingTask {
  id          String   @id @default(cuid())
  campaignId  String
  title       String
  description String
  orderIndex  Int
  createdAt   DateTime @default(now())
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, orderIndex])
}

model BugReport {
  id                String        @id @default(cuid())
  campaignId        String
  testerId          String
  moderatorId       String?
  validatedById     String?
  title             String
  description       String
  reproductionSteps String
  expectedResult    String
  actualResult      String
  severity          BugSeverity
  environment       Json
  status            BugStatus     @default(SUBMITTED)
  moderationNotes   String?
  validationNotes   String?
  duplicateOfId     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  campaign          Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tester            User          @relation("ReporterBugs", fields: [testerId], references: [id], onDelete: Cascade)
  moderator         User?         @relation("ModeratorBugs", fields: [moderatorId], references: [id], onDelete: SetNull)
  validatedBy       User?         @relation("ManagerBugs", fields: [validatedById], references: [id], onDelete: SetNull)
  attachments       BugAttachment[]

  @@index([campaignId, status])
  @@index([testerId, severity])
}

model BugAttachment {
  id           String         @id @default(cuid())
  bugReportId  String
  kind         AttachmentKind
  originalName String
  storedName   String
  relativePath String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime       @default(now())
  bugReport    BugReport      @relation(fields: [bugReportId], references: [id], onDelete: Cascade)

  @@index([bugReportId])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorId    String?
  campaignId String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime  @default(now())
  actor      User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([campaignId, createdAt])
}

model EmailToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}
